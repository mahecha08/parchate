<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Parchate" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/parchate_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/parchate_background</item>
    </style>

    <style name="Theme.Parchate.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/parchate_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_empty</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/parchate_background</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.Parchate</item>
    </style>
</resources>
